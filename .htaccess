# cPanel subdomain document root = e-learning.uosj.ac.ug/ (project root)
# No need to change document root — this file routes traffic to public/index.php

<IfModule mod_rewrite.c>
    Options +FollowSymLinks -Indexes
    RewriteEngine On
    RewriteBase /

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Pass Authorization header to PHP
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Block direct web access to Laravel internals
    RewriteRule ^(\.env|\.git|app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L]

    # /public/* URLs — serve static files (matches ASSET_URL=.../public)
    RewriteRule ^public/ - [L]

    # Map /assets, /images, etc. to files inside public/
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -d
    RewriteRule ^(.*)$ public/$1 [L]

    # Application routes → Laravel front controller
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>

<IfModule LiteSpeed>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
    FallbackResource /public/index.php
</IfModule>

<Files .env>
    Require all denied
</Files>

<Files .env.cpanel>
    Require all denied
</Files>
